let mapleader = " "

set scrolloff=10
set relativenumber
set showmode
set showcmd
set visualbell
set clipboard+=unnamed

set ignorecase
set smartcase
set incsearch
set hlsearch

set highlightedyank
set ideajoin
set nerdtree

map <leader>q <action>(CloseContent)

map <leader>gc <Action>(ActivateGitHubCopilotToolWindow)

map <leader>ff <action>(GotoFile)
map <leader>fr <action>(RecentFiles)
map <leader>fc <action>(FindInPath)

" Go to code
nmap <leader>gd <Action>(GotoDeclaration)
nmap <leader>gu <Action>(ShowUsages)

" === Split windows ===
map <leader>wv <Action>(SplitVertically)
map <leader>ws <Action>(SplitHorizontally)

" Open NERDTree (use q to exit)
map <leader>e :NERDTreeToggle<CR>

" Folding
map <leader>c :action CollapseAllRegions<CR>
map <leader>o :action ExpandAllRegions<CR>

" === Navigation between buffers (tabs) ===
nnoremap <S-h> :action PreviousTab<CR>
nnoremap <S-l> :action NextTab<CR>

nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz

" === Move between panes ===
nnoremap <leader>h <C-w>h
nnoremap <leader>j <C-w>j
nnoremap <leader>k <C-w>k
nnoremap <leader>l <C-w>l

" === Visual Mode ===
" Indent while staying in visual mode
vnoremap < <gv
vnoremap > >gv

" Move selected lines up/down
vnoremap J :m '>+1<CR>gv=gv
vnoremap K :m '<-2<CR>gv=gv

vnoremap <leader>c :action CommentByLineComment<CR>
